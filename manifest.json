{
  "manifest_version": 3,
  "name": "Web Context Picker",
  "version": "0.1.0",
  "description": "Click elements on a page to copy them as markdown context.",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Web Context Picker (Ctrl+Shift+X)"
  },
  "commands": {
    "toggle-picker": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Toggle element picker on the active tab"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["console_hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["picker.css"],
      "run_at": "document_idle"
    }
  ]
}
